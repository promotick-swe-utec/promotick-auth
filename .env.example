# =============================================================================
# promotick-auth — variables de entorno
# =============================================================================
# Este archivo NO se usa en producción: en AWS las variables las inyecta
# serverless.yml leyendo los Outputs de la stack `promotick-infra`.
#
# Copia este archivo a `.env` SOLO para pruebas locales (pytest contra moto,
# scripts ad-hoc). Nunca commitees `.env` real.
# =============================================================================

# Región fija del proyecto.
AWS_REGION=us-east-1

# DynamoDB — tabla maestra de perfiles de usuario (PK: user_id).
# En AWS proviene de: ${cf:promotick-infra-dynamodb.UsersTableName}
USERS_TABLE_NAME=promotick_users

# Cognito User Pool — `promotick-user-pool`.
# En AWS proviene de: ${cf:promotick-infra-cognito.UserPoolId}
USER_POOL_ID=us-east-1_Q5nCsmNvQ

# Cognito App Client (ADMIN_USER_PASSWORD_AUTH habilitado).
# En AWS proviene de: ${cf:promotick-infra-cognito.UserPoolClientId}
USER_POOL_CLIENT_ID=22nufntg8k3sfqief7en93ius9

# (Opcional) Stage del deploy. Default: dev.
STAGE=dev
