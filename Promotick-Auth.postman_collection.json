  "item": [
    {
      "name": "Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json && json.tokens && json.tokens.access_token) {",
              "    pm.collectionVariables.set('accessToken', json.tokens.access_token);",
              "    console.log('accessToken guardado en collection variables');",
              "  }",
              "  if (json && json.session) {",
              "    pm.collectionVariables.set('cognitoSession', json.session);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
